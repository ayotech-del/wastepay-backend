# WastePay Nigeria — Environment Variables
# Copy this to .env and fill in your values

DATABASE_URL=postgresql://wastepay_user:your_password@localhost:5432/wastepay

SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Paystack (CBN-licensed payment processor)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key

# Prembly (BVN + NIN KYC verification)
PREMBLY_API_KEY=your_prembly_api_key

# Africa's Talking (USSD *932#)
AT_USERNAME=wastepay
AT_API_KEY=your_africas_talking_api_key

# Firebase (push notifications)
FIREBASE_CREDENTIALS=path/to/firebase-credentials.json

# Optional: override default credit rates (NGN per kg)
# RATE_PLASTIC=400
# RATE_METAL=600
# RATE_ELECTRONICS=1200
